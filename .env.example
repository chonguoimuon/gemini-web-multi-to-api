# Server Configuration
PORT=4982
LOG_LEVEL=info
APP_ENV=development

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300

# Admin Dashboard & Swagger
# Security token to access the /swagger/index.html UI and add multiple cookies
ADMIN_API_KEY=your_secure_password

# Gemini Configuration (Optional since you can add via Swagger UI)
# To get these values, visit https://gemini.google.com and log in
# Then open Developer Tools (F12) -> Application/Storage tab -> Cookies -> https://google.com
#GEMINI_1PSID=
#GEMINI_1PSIDTS=
GEMINI_REFRESH_INTERVAL=60
GEMINI_MAX_RETRIES=3

# NOTE: LOG_RAW_REQUESTS and AUTO_DELETE_CHAT are now managed via Admin API (/admin/v1/config)
# and saved to data/runtime_config.json — do NOT set them here.

# Self-Healing Oracle (Gemini Pro API Keys for Zero-Config recovery)
# Format as JSON array: ["key1", "key2"]
GEMINI_PRO_API_KEYS=[]

# MCP Configuration (Model Context Protocol)
MCP_ENABLED=true
MCP_TRANSPORT=sse
# When using SSE, Antigravity will connect to https://yourdomain.com/mcp/sse
# Authorization: Bearer <ADMIN_API_KEY>

# Chu kỳ tự động kiểm tra và cấu hình lại (Self-Healing) cho tài khoản Guest (tính bằng giờ)
# Nếu tất cả các Cookie bị lỗi, hệ thống sẽ ưu tiên dùng cấu hình Guest mới nhất.
GEMINI_GUEST_REFRESH_INTERVAL_HOURS=24

# --- Long Prompt Chunking ---
# Cấu hình kích thước tối đa (số ký tự/rune) cho mỗi gói tin khi gửi prompts dài.
# Nếu prompt vượt quá giới hạn này, hệ thống sẽ tự động chia nhỏ để tránh bị Google ban.
# (Mặc định: 32000)
GEMINI_PACK_CONTEXT=32000
