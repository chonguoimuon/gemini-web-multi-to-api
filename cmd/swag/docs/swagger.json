                            "additionalProperties": true
                        }
                    }
                }
            },
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Injects a new __Secure-1PSID and __Secure-1PSIDTS for load balancing and rotation",
